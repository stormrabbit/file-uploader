{
  "name": "file-uploader-server",
  "version": "1.0.0",
  "description": "局域网内上传文件 - 后端服务",
  "author": "二狗",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:fresh": "fkill :38902 --silent --force && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:node": "node dist/main.js",
    "start:prod": "pm2 start dist/main.js --name='fu-server'",
    "stop:prod": "pm2 stop fu-server",
    "remove:prod": "pm2 delete fu-server",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "overrides": {
    "colors": "1.4.0"
  },
  "dependencies": {
    "@nestjs/common": "^7.6.15",
    "@nestjs/core": "^7.6.15",
    "@nestjs/platform-express": "^7.6.15",
    "@nestjs/swagger": "^4.8.0",
    "@prisma/client": "^5.22.0",
    "chalk": "^3.0.0",
    "dayjs": "^1.10.4",
    "dotenv": "^17.4.2",
    "log4js": "^6.3.0",
    "multer": "^1.4.2",
    "nuid": "^1.1.6",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^6.6.7",
    "stacktrace-js": "^2.0.2",
    "swagger-ui-express": "^4.1.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^7.6.0",
    "@nestjs/schematics": "^7.3.0",
    "@nestjs/testing": "^7.6.15",
    "@types/express": "^4.17.11",
    "@types/jest": "^26.0.22",
    "@types/multer": "^1.4.11",
    "@types/node": "^14.14.36",
    "@types/supertest": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^7.22.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "fkill-cli": "^7.1.0",
    "jest": "^26.6.3",
    "prettier": "^2.2.1",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "supertest": "^6.1.3",
    "ts-jest": "^26.5.4",
    "ts-loader": "^8.0.18",
    "ts-node": "^9.1.1",
    "tsconfig-paths": "^3.9.0",
    "typescript": "^4.9.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
